#!/usr/bin/env bash
# muninn — memory for your GitHub estate. Reports on $MUNINN_ROOT (default ~/github-repos).
# Odin's other raven — huginn's twin: huginn is the present, muninn is the past and its narrative.
#
#   muninn log | releases | digest | init
#   run 'muninn help' for the menu, or 'muninn <command> help' for per-command detail.
set -uo pipefail
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"; HERE="$(cd "$(dirname "$SELF")" && pwd)"

# ── configuration — env  >  config file  >  smart defaults ────────────────
CONFIG="${MUNINN_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/muninn/config}"
for _v in ROOT OWNER FAMILY SINCE; do eval "_env_$_v=\${MUNINN_$_v-}"; done
[ -f "$CONFIG" ] && . "$CONFIG"

# free config for huginn users — if MUNINN_* is unset, fall back to huginn's config
HCONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/huginn/config"
[ -f "$HCONFIG" ] && . "$HCONFIG"

ROOT="${_env_ROOT:-${MUNINN_ROOT:-${HUGINN_ROOT:-$HOME/github-repos}}}"
OWNER="${_env_OWNER:-${MUNINN_OWNER:-${HUGINN_OWNER:-}}}"          # resolved lazily — see need_owner
FAMILY="${_env_FAMILY:-${MUNINN_FAMILY:-${HUGINN_FAMILY:-}}}"      # space-separated repos to exclude
SINCE="${_env_SINCE:-${MUNINN_SINCE:-1w}}"                         # default --since window

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; C=$'\e[36m'; M=$'\e[35m'; DIM=$'\e[2m'; BD=$'\e[1m'; X=$'\e[0m'
else R=; G=; Y=; C=; M=; DIM=; BD=; X=; fi

is_family(){ case " $FAMILY " in *" $1 "*) return 0;; *) return 1;; esac; }
is_help(){ case "${1:-}" in help|-h|--help) return 0;; *) return 1;; esac; }
repos(){ (cd "$ROOT" && for d in */; do [ -d "${d}.git" ] && echo "${d%/}"; done | sort); }
need_owner(){ [ -n "$OWNER" ] && return 0; OWNER="$(gh api user --jq .login 2>/dev/null)"; [ -n "$OWNER" ] && return 0; printf "  ${R}no GitHub owner set.${X} Set MUNINN_OWNER, add it to %s, or run ${BD}muninn init${X}.\n" "$CONFIG" >&2; return 1; }

# turn a window like 1w/3d/2mo into a git-approxidate string ("N weeks ago")
since_to_gitdate(){
  local w="$1"
  [[ "$w" =~ ^([0-9]+)(mo|[dwh])$ ]] || return 1
  local n="${BASH_REMATCH[1]}" u="${BASH_REMATCH[2]}"
  case "$u" in
    h)  printf '%s hours ago' "$n";;
    d)  printf '%s days ago' "$n";;
    w)  printf '%s weeks ago' "$n";;
    mo) printf '%s months ago' "$n";;
  esac
}
# epoch seconds -> short age ("2d", "5w", …), for timeline rows
age_short(){
  local now diff; now=$(date +%s); diff=$(( now - $1 )); [ "$diff" -lt 0 ] && diff=0
  if   [ "$diff" -lt 3600 ];    then printf '%dm'  $(( diff/60 ))
  elif [ "$diff" -lt 86400 ];   then printf '%dh'  $(( diff/3600 ))
  elif [ "$diff" -lt 604800 ];  then printf '%dd'  $(( diff/86400 ))
  elif [ "$diff" -lt 2592000 ]; then printf '%dw'  $(( diff/604800 ))
  else                               printf '%dmo' $(( diff/2592000 ))
  fi
}
plural(){ [ "${1:-0}" = 1 ] && printf '' || printf 's'; }
# escape the markdown chars most likely to mangle a raw commit/PR title
md_escape(){ sed -E 's/([`*_])/\\\1/g' <<<"$1"; }
# "Jun 25–Jul 2, 2026" — start date omits the year when it matches the end date's
digest_daterange(){
  local since_epoch="$1" now="$2" syear eyear sfmt
  syear="$(date -d "@$since_epoch" +%Y)"; eyear="$(date -d "@$now" +%Y)"
  if [ "$syear" = "$eyear" ]; then sfmt="$(date -d "@$since_epoch" +'%b %-d')"
  else sfmt="$(date -d "@$since_epoch" +'%b %-d, %Y')"; fi
  printf '%s–%s' "$sfmt" "$(date -d "@$now" +'%b %-d, %Y')"
}

# ── log (activity timeline — commits, merged PRs, releases) ───────────────
cmd_log(){
  is_help "${1:-}" && { help_log; return 0; }
  local since="$SINCE" target=""
  while [ $# -gt 0 ]; do case "$1" in
    --since) shift; since="${1:-$SINCE}";;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$1";;
    *) target="$1";;
  esac; shift; done

  local sincegit; sincegit="$(since_to_gitdate "$since")" || {
    printf "  ${R}invalid --since window:${X} %s ${DIM}(expected e.g. 1w, 3d, 2mo)${X}\n" "$since"; return 1; }
  local since_epoch since_iso
  since_epoch="$(date -d "$sincegit" +%s 2>/dev/null)" || since_epoch=0
  since_iso="$(date -d "$sincegit" +%Y-%m-%d 2>/dev/null)"

  if [ -n "$target" ] && [ ! -d "$ROOT/$target/.git" ]; then
    printf "  ${R}no such repo:${X} %s ${DIM}(under %s)${X}\n" "$target" "$ROOT"; return 1
  fi
  need_owner || return 1

  local EVENTS; EVENTS="$(mktemp)"
  trap 'rm -f "$EVENTS"' RETURN

  # commits — local, fast. Merge commits are skipped (the PR they merged is
  # already an event of its own); busy repos collapse to a single count line.
  while read -r d; do
    [ -n "$target" ] && [ "$d" != "$target" ] && continue
    is_family "$d" && continue
    local GD="$ROOT/$d" def ref
    def="$(git -C "$GD" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"; def="${def:-main}"
    if git -C "$GD" rev-parse --verify -q "refs/remotes/origin/$def" >/dev/null 2>&1; then ref="origin/$def"
    elif git -C "$GD" rev-parse --verify -q "refs/heads/$def" >/dev/null 2>&1; then ref="$def"
    else ref="HEAD"; fi

    local rows nrows
    rows="$(git -C "$GD" log --no-merges --since="$sincegit" --format='%at%x09%s' "$ref" 2>/dev/null)"
    [ -z "$rows" ] && continue
    nrows="$(wc -l <<<"$rows")"
    if [ "$nrows" -gt 5 ]; then
      printf '%s\x1f%s\x1fcommits\x1f%s\x1f\n' "$(cut -f1 <<<"$rows" | head -1)" "$d" "$nrows" >> "$EVENTS"
    else
      while IFS=$'\t' read -r at msg; do
        printf '%s\x1f%s\x1fcommit\x1f\x1f%s\n' "$at" "$d" "$msg" >> "$EVENTS"
      done <<< "$rows"
    fi
  done < <(repos)

  # merged PRs — one estate-wide search covers every repo (network)
  # NOTE: field separator is U+001F, not tab — bash `read` collapses
  # consecutive tab/space/newline delimiters even with a custom tab IFS,
  # which silently drops empty fields (e.g. an unnamed release) and
  # shifts everything after them. \x1f is a real, non-collapsing delimiter.
  local prrows
  prrows="$(gh search prs --owner "$OWNER" --merged --merged-at ">=$since_iso" --limit 200 \
    --json repository,number,title,closedAt --jq '.[] | [.repository.name,(.number|tostring),.title,.closedAt] | @tsv' 2>/dev/null | tr '\t' '\037')"
  while IFS=$'\x1f' read -r repo num title closedAt; do
    [ -z "$repo" ] && continue
    [ -n "$target" ] && [ "$repo" != "$target" ] && continue
    is_family "$repo" && continue
    local at; at="$(date -d "$closedAt" +%s 2>/dev/null)" || continue
    printf '%s\x1f%s\x1fpr\x1f%s\x1f%s\n' "$at" "$repo" "$num" "$title" >> "$EVENTS"
  done <<< "$prrows"

  # releases (gh, network) + any plain git tags a release doesn't cover (local)
  while read -r d; do
    [ -n "$target" ] && [ "$d" != "$target" ] && continue
    is_family "$d" && continue
    local GD="$ROOT/$d" rj seen=" "
    rj="$(gh release list -R "$OWNER/$d" --limit 10 --json tagName,name,publishedAt 2>/dev/null)"
    if [ -n "$rj" ] && [ "$rj" != "[]" ]; then
      while IFS=$'\x1f' read -r tag rname pub; do
        [ -z "$tag" ] && continue
        seen="$seen$tag "
        local at; at="$(date -d "$pub" +%s 2>/dev/null)" || continue
        [ "$at" -lt "$since_epoch" ] && continue
        local sub=""
        if [ -n "$rname" ] && [ "$rname" != "$tag" ]; then
          if [ "${rname#"$tag"}" != "$rname" ]; then
            sub="$(sed -E 's/^[[:space:]]*[—:-]+[[:space:]]*//' <<<"${rname#"$tag"}")"
          else sub="$rname"; fi
        fi
        printf '%s\x1f%s\x1frelease\x1f%s\x1f%s\n' "$at" "$d" "$tag" "$sub" >> "$EVENTS"
      done < <(printf '%s' "$rj" | jq -r '.[] | [.tagName,.name,.publishedAt] | @tsv' | tr '\t' '\037')
    fi
    while read -r tg; do
      [ -z "$tg" ] && continue
      case "$seen" in *" $tg "*) continue;; esac
      local tat; tat="$(git -C "$GD" log -1 --format=%at "$tg" 2>/dev/null)"
      [ -z "$tat" ] && continue
      [ "$tat" -lt "$since_epoch" ] && continue
      printf '%s\x1f%s\x1frelease\x1f%s\x1f\n' "$tat" "$d" "$tg" >> "$EVENTS"
    done < <(git -C "$GD" tag -l 2>/dev/null)
  done < <(repos)

  if [ ! -s "$EVENTS" ]; then
    printf "\n  ${DIM}nothing since %s%s${X}\n\n" "$since" "$([ -n "$target" ] && echo " · $target")"
    return 0
  fi

  printf "\n  ${BD}muninn log${X}  ${DIM}· since %s%s${X}\n\n" "$since" "$([ -n "$target" ] && echo " · $target")"

  local n=0 at repo type fa fb
  while IFS=$'\x1f' read -r at repo type fa fb; do
    case "$type" in
      pr)      printf "  ${DIM}%-3s${X}  ${BD}%-24s${X}  ${C}⑃${X} ${BD}#%s${X}  %s  ${DIM}(merged)${X}\n" "$(age_short "$at")" "$repo" "$fa" "$fb";;
      release) printf "  ${DIM}%-3s${X}  ${BD}%-24s${X}  ${G}⚑${X} ${BD}%s${X}  %s\n" "$(age_short "$at")" "$repo" "$fa" "$fb";;
      commits) printf "  ${DIM}%-3s${X}  ${BD}%-24s${X}  ${DIM}●${X}  %s commits\n" "$(age_short "$at")" "$repo" "$fa";;
      commit)  printf "  ${DIM}%-3s${X}  ${BD}%-24s${X}  ${DIM}●${X}  %s\n" "$(age_short "$at")" "$repo" "$fb";;
    esac
    n=$((n+1))
  done < <(sort -t $'\x1f' -k1,1nr "$EVENTS")

  printf "\n  ${BD}%d events${X} ${DIM}since %s${X}\n\n" "$n" "$since"
}

# ── releases (changelog-of-changelogs) ─────────────────────────────────────
cmd_releases(){
  is_help "${1:-}" && { help_releases; return 0; }
  need_owner || return 1

  printf "\n  ${BD}muninn releases${X}  ${DIM}· changelog-of-changelogs${X}\n"

  local nrepos=0 ntotal=0
  while read -r d; do
    is_family "$d" && continue
    local GD="$ROOT/$d" rj seen=" "
    local -a ROWS=()
    rj="$(gh release list -R "$OWNER/$d" --limit 100 --json tagName,name,publishedAt,isPrerelease 2>/dev/null)"
    if [ -n "$rj" ] && [ "$rj" != "[]" ]; then
      while IFS=$'\x1f' read -r tag rname pub pre; do
        [ -z "$tag" ] && continue
        seen="$seen$tag "
        local at; at="$(date -d "$pub" +%s 2>/dev/null)" || continue
        local dt; dt="$(date -d "$pub" +%Y-%m-%d 2>/dev/null)"
        local sub=""
        if [ -n "$rname" ] && [ "$rname" != "$tag" ]; then
          if [ "${rname#"$tag"}" != "$rname" ]; then
            sub="$(sed -E 's/^[[:space:]]*[—:-]+[[:space:]]*//' <<<"${rname#"$tag"}")"
          else sub="$rname"; fi
        fi
        ROWS+=("$at"$'\x1f'"$tag"$'\x1f'"$dt"$'\x1f'"$sub"$'\x1f'"$pre")
      done < <(printf '%s' "$rj" | jq -r '.[] | [.tagName,.name,.publishedAt,(.isPrerelease|tostring)] | @tsv' | tr '\t' '\037')
    fi
    while read -r tg; do
      [ -z "$tg" ] && continue
      case "$seen" in *" $tg "*) continue;; esac
      local tat; tat="$(git -C "$GD" log -1 --format=%at "$tg" 2>/dev/null)"
      [ -z "$tat" ] && continue
      local tdt; tdt="$(date -d "@$tat" +%Y-%m-%d 2>/dev/null)"
      ROWS+=("$tat"$'\x1f'"$tg"$'\x1f'"$tdt"$'\x1f'""$'\x1f'"false")
    done < <(git -C "$GD" tag -l 2>/dev/null)

    [ "${#ROWS[@]}" -eq 0 ] && continue
    nrepos=$((nrepos+1))
    printf "\n  ${BD}%s${X}\n" "$d"
    while IFS=$'\x1f' read -r at tag dt sub pre; do
      if [ "$pre" = "true" ]; then
        printf "    ${BD}%-10s${X}  ${DIM}%s${X}  %s ${Y}(pre)${X}\n" "$tag" "$dt" "$sub"
      else
        printf "    ${BD}%-10s${X}  ${DIM}%s${X}  %s\n" "$tag" "$dt" "$sub"
      fi
      ntotal=$((ntotal+1))
    done < <(printf '%s\n' "${ROWS[@]}" | sort -t $'\x1f' -k1,1nr)
  done < <(repos)

  if [ "$nrepos" -eq 0 ]; then
    printf "\n  ${DIM}no tags or releases found anywhere in the estate${X}\n\n"
    return 0
  fi
  printf "\n  ${BD}%d releases${X} ${DIM}across %d repos${X}\n\n" "$ntotal" "$nrepos"
}

# ── digest (written summary of what shipped) ───────────────────────────────
cmd_digest(){
  is_help "${1:-}" && { help_digest; return 0; }
  local since="$SINCE" md=0
  while [ $# -gt 0 ]; do case "$1" in
    --since) shift; since="${1:-$SINCE}";;
    --md) md=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$1";;
    *) printf "  ${Y}ignoring unexpected argument: %s${X}\n" "$1";;
  esac; shift; done

  local sincegit; sincegit="$(since_to_gitdate "$since")" || {
    printf "  ${R}invalid --since window:${X} %s ${DIM}(expected e.g. 1w, 3d, 2mo)${X}\n" "$since"; return 1; }
  local since_epoch since_iso now
  since_epoch="$(date -d "$sincegit" +%s 2>/dev/null)" || since_epoch=0
  since_iso="$(date -d "$sincegit" +%Y-%m-%d 2>/dev/null)"
  now="$(date +%s)"
  need_owner || return 1

  local -a ALL_REPOS; mapfile -t ALL_REPOS < <(repos)
  local -A CNT_COMMITS=() DEFAULT_BRANCH=() PR_ITEMS=() REL_ITEMS=()
  local d

  # commits — local, fast; always collapsed to a count (this is a summary, not a timeline)
  for d in "${ALL_REPOS[@]}"; do
    is_family "$d" && continue
    local GD="$ROOT/$d" def ref
    def="$(git -C "$GD" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"; def="${def:-main}"
    if git -C "$GD" rev-parse --verify -q "refs/remotes/origin/$def" >/dev/null 2>&1; then ref="origin/$def"
    elif git -C "$GD" rev-parse --verify -q "refs/heads/$def" >/dev/null 2>&1; then ref="$def"
    else ref="HEAD"; fi
    local cnt; cnt="$(git -C "$GD" log --no-merges --since="$sincegit" --oneline "$ref" 2>/dev/null | wc -l)"
    [ "$cnt" -gt 0 ] && { CNT_COMMITS[$d]="$cnt"; DEFAULT_BRANCH[$d]="$def"; }
  done

  # merged PRs — one estate-wide search, bucketed per repo, ascending by number
  local prrows
  prrows="$(gh search prs --owner "$OWNER" --merged --merged-at ">=$since_iso" --limit 200 \
    --json repository,number,title --jq 'sort_by(.number) | .[] | [.repository.name,(.number|tostring),.title] | @tsv' 2>/dev/null | tr '\t' '\037')"
  while IFS=$'\x1f' read -r repo num title; do
    [ -z "$repo" ] && continue
    is_family "$repo" && continue
    if [ -n "${PR_ITEMS[$repo]:-}" ]; then PR_ITEMS[$repo]="${PR_ITEMS[$repo]}"$'\n'"$num"$'\x1f'"$title"
    else PR_ITEMS[$repo]="$num"$'\x1f'"$title"; fi
  done <<< "$prrows"

  # releases (gh, network) + plain git tags a release doesn't cover — newest first per repo
  for d in "${ALL_REPOS[@]}"; do
    is_family "$d" && continue
    local GD="$ROOT/$d" rj seen=" "
    rj="$(gh release list -R "$OWNER/$d" --limit 10 --json tagName,name,publishedAt 2>/dev/null)"
    if [ -n "$rj" ] && [ "$rj" != "[]" ]; then
      while IFS=$'\x1f' read -r tag rname pub; do
        [ -z "$tag" ] && continue
        seen="$seen$tag "
        local at; at="$(date -d "$pub" +%s 2>/dev/null)" || continue
        [ "$at" -lt "$since_epoch" ] && continue
        local sub=""
        if [ -n "$rname" ] && [ "$rname" != "$tag" ]; then
          if [ "${rname#"$tag"}" != "$rname" ]; then
            sub="$(sed -E 's/^[[:space:]]*[—:-]+[[:space:]]*//' <<<"${rname#"$tag"}")"
          else sub="$rname"; fi
        fi
        if [ -n "${REL_ITEMS[$d]:-}" ]; then REL_ITEMS[$d]="${REL_ITEMS[$d]}"$'\n'"$tag"$'\x1f'"$sub"
        else REL_ITEMS[$d]="$tag"$'\x1f'"$sub"; fi
      done < <(printf '%s' "$rj" | jq -r '.[] | [.tagName,.name,.publishedAt] | @tsv' | tr '\t' '\037')
    fi
    while read -r tg; do
      [ -z "$tg" ] && continue
      case "$seen" in *" $tg "*) continue;; esac
      local tat; tat="$(git -C "$GD" log -1 --format=%at "$tg" 2>/dev/null)"
      [ -z "$tat" ] && continue
      [ "$tat" -lt "$since_epoch" ] && continue
      if [ -n "${REL_ITEMS[$d]:-}" ]; then REL_ITEMS[$d]="${REL_ITEMS[$d]}"$'\n'"$tg"$'\x1f'""
      else REL_ITEMS[$d]="$tg"$'\x1f'""; fi
    done < <(git -C "$GD" tag -l 2>/dev/null)
  done

  # totals + touched-repo count
  local total_commits=0 total_prs=0 total_rel=0 nrepos=0
  for d in "${ALL_REPOS[@]}"; do
    is_family "$d" && continue
    local touched=0
    if [ -n "${CNT_COMMITS[$d]:-}" ]; then total_commits=$(( total_commits + CNT_COMMITS[$d] )); touched=1; fi
    if [ -n "${PR_ITEMS[$d]:-}" ]; then total_prs=$(( total_prs + $(wc -l <<<"${PR_ITEMS[$d]}") )); touched=1; fi
    if [ -n "${REL_ITEMS[$d]:-}" ]; then total_rel=$(( total_rel + $(wc -l <<<"${REL_ITEMS[$d]}") )); touched=1; fi
    [ "$touched" -eq 1 ] && nrepos=$((nrepos+1))
  done

  if [ "$md" = 1 ]; then
    printf '# What shipped — %s\n\n' "$(digest_daterange "$since_epoch" "$now")"
    if [ "$nrepos" -eq 0 ]; then printf 'Nothing shipped since %s.\n' "$since"; return 0; fi
    printf 'Across %d repo%s: %d commit%s · %d PR%s merged · %d release%s.\n' \
      "$nrepos" "$(plural "$nrepos")" "$total_commits" "$(plural "$total_commits")" \
      "$total_prs" "$(plural "$total_prs")" "$total_rel" "$(plural "$total_rel")"
    for d in "${ALL_REPOS[@]}"; do
      is_family "$d" && continue
      [ -z "${CNT_COMMITS[$d]:-}" ] && [ -z "${PR_ITEMS[$d]:-}" ] && [ -z "${REL_ITEMS[$d]:-}" ] && continue
      printf '\n## %s\n' "$d"
      if [ -n "${REL_ITEMS[$d]:-}" ]; then
        while IFS=$'\x1f' read -r tag sub; do
          [ -z "$tag" ] && continue
          if [ -n "$sub" ]; then printf -- '- Released **%s** — %s\n' "$tag" "$(md_escape "$sub")"
          else printf -- '- Released **%s**\n' "$tag"; fi
        done <<< "${REL_ITEMS[$d]}"
      fi
      if [ -n "${PR_ITEMS[$d]:-}" ]; then
        local prn; prn="$(wc -l <<<"${PR_ITEMS[$d]}")"
        if [ "$prn" -gt 8 ]; then
          printf -- '- Merged %d PRs\n' "$prn"
        else
          local joined=""
          while IFS=$'\x1f' read -r num title; do
            [ -z "$num" ] && continue
            local frag="#$num $(md_escape "$title")"
            if [ -n "$joined" ]; then joined="$joined · $frag"; else joined="$frag"; fi
          done <<< "${PR_ITEMS[$d]}"
          printf -- '- Merged %s\n' "$joined"
        fi
      fi
      if [ -n "${CNT_COMMITS[$d]:-}" ]; then
        local c="${CNT_COMMITS[$d]}" onlyc=0
        [ -z "${PR_ITEMS[$d]:-}" ] && [ -z "${REL_ITEMS[$d]:-}" ] && onlyc=1
        if [ "$onlyc" = 1 ]; then printf -- '- %d commit%s on `%s`\n' "$c" "$(plural "$c")" "${DEFAULT_BRANCH[$d]}"
        else printf -- '- %d commit%s\n' "$c" "$(plural "$c")"; fi
      fi
    done
    return 0
  fi

  printf "\n  ${BD}muninn digest${X}  ${DIM}· %s${X}\n\n" "$(digest_daterange "$since_epoch" "$now")"
  if [ "$nrepos" -eq 0 ]; then
    printf "  ${DIM}nothing shipped since %s${X}\n\n" "$since"
    return 0
  fi
  printf "  Across ${BD}%d${X} repo%s: ${BD}%d${X} commit%s · ${BD}%d${X} PR%s merged · ${BD}%d${X} release%s\n" \
    "$nrepos" "$(plural "$nrepos")" "$total_commits" "$(plural "$total_commits")" \
    "$total_prs" "$(plural "$total_prs")" "$total_rel" "$(plural "$total_rel")"
  for d in "${ALL_REPOS[@]}"; do
    is_family "$d" && continue
    [ -z "${CNT_COMMITS[$d]:-}" ] && [ -z "${PR_ITEMS[$d]:-}" ] && [ -z "${REL_ITEMS[$d]:-}" ] && continue
    printf "\n  ${BD}%s${X}\n" "$d"
    if [ -n "${REL_ITEMS[$d]:-}" ]; then
      while IFS=$'\x1f' read -r tag sub; do
        [ -z "$tag" ] && continue
        if [ -n "$sub" ]; then printf "    ${G}⚑${X} Released ${BD}%s${X} — %s\n" "$tag" "$sub"
        else printf "    ${G}⚑${X} Released ${BD}%s${X}\n" "$tag"; fi
      done <<< "${REL_ITEMS[$d]}"
    fi
    if [ -n "${PR_ITEMS[$d]:-}" ]; then
      local prn; prn="$(wc -l <<<"${PR_ITEMS[$d]}")"
      if [ "$prn" -gt 8 ]; then
        printf "    ${C}⑃${X} Merged ${BD}%d${X} PRs\n" "$prn"
      else
        local joined=""
        while IFS=$'\x1f' read -r num title; do
          [ -z "$num" ] && continue
          local frag="#$num $title"
          if [ -n "$joined" ]; then joined="$joined · $frag"; else joined="$frag"; fi
        done <<< "${PR_ITEMS[$d]}"
        printf "    ${C}⑃${X} Merged %s\n" "$joined"
      fi
    fi
    if [ -n "${CNT_COMMITS[$d]:-}" ]; then
      local c="${CNT_COMMITS[$d]}" onlyc=0
      [ -z "${PR_ITEMS[$d]:-}" ] && [ -z "${REL_ITEMS[$d]:-}" ] && onlyc=1
      if [ "$onlyc" = 1 ]; then printf "    ${DIM}●${X} %d commit%s on ${C}%s${X}\n" "$c" "$(plural "$c")" "${DEFAULT_BRANCH[$d]}"
      else printf "    ${DIM}●${X} %d commit%s\n" "$c" "$(plural "$c")"; fi
    fi
  done
  printf "\n"
}

# ── init (write a config file) ─────────────────────────────────────────────
cmd_init(){
  is_help "${1:-}" && { help_init; return 0; }
  local force=0; [ "${1:-}" = "--force" ] && force=1
  mkdir -p "$(dirname "$CONFIG")"
  if [ -f "$CONFIG" ] && [ "$force" = 0 ]; then
    printf "\n  config already exists → ${C}%s${X}\n  ${DIM}edit it directly, or 'muninn init --force' to overwrite.${X}\n\n" "$CONFIG"; return 0
  fi
  local o; o="$(gh api user --jq .login 2>/dev/null)"
  cat > "$CONFIG" <<CFG
# muninn configuration — https://github.com/brett-buskirk/muninn
MUNINN_OWNER="$o"
MUNINN_ROOT="\$HOME/github-repos"
MUNINN_FAMILY=""    # space-separated repos to exclude
MUNINN_SINCE="1w"   # default --since window for log/digest
CFG
  printf "\n  ${G}✓${X} wrote ${C}%s${X}\n\n" "$CONFIG"
  sed 's/^/    /' "$CONFIG"
  printf "\n  ${DIM}edit as needed — env vars (MUNINN_*) override the file. If unset here,\n"
  printf "  MUNINN_ROOT/OWNER/FAMILY still fall back to ~/.config/huginn/config when\n"
  printf "  present, so this file only needs the keys you want to diverge on.${X}\n\n"
}

# ── per-command help ───────────────────────────────────────────────────────
help_log(){
  printf "\n  ${BD}muninn log${X} [--since <window>] [repo]\n\n"
  printf "  A unified, reverse-chronological activity timeline across the whole estate —\n"
  printf "  merged PRs (${C}⑃${X}), releases/tags (${G}⚑${X}), and commits (${DIM}●${X}), interleaved, newest first.\n"
  printf "  A repo with more than 5 non-merge commits in the window collapses to a single\n"
  printf "  ${DIM}●${X} N commits line so a busy week doesn't scroll forever.\n\n"
  printf "  ${BD}Arguments${X}\n"
  printf "    repo            scope the timeline to a single repo\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --since <window>  a window like 1w, 3d, 2mo ${DIM}(default: %s)${X}\n\n" "$SINCE"
  printf "  ${DIM}Commits are local & fast; merged PRs are one estate-wide search; releases/tags\n"
  printf "  are looked up per repo — the network cost of a full sweep, like 'doctor'.${X}\n\n"
}
help_releases(){
  printf "\n  ${BD}muninn releases${X}\n\n"
  printf "  Every tag/release across the estate — a changelog-of-changelogs. One block\n"
  printf "  per repo (repos with none are omitted), newest first within each: version,\n"
  printf "  date, release title. Plain git tags without a matching GitHub release are\n"
  printf "  folded in too; pre-releases are flagged ${Y}(pre)${X}.\n\n"
  printf "  ${DIM}Network — pulls 'gh release list' (up to 100 per repo) plus git tags,\n"
  printf "  once per repo in the estate — the same cost class as 'doctor'.${X}\n\n"
}
help_digest(){
  printf "\n  ${BD}muninn digest${X} [--since <window>] [--md]\n\n"
  printf "  A written summary of what shipped in the window — the headline feature.\n"
  printf "  Repos with nothing in the window are omitted; for each repo touched, in\n"
  printf "  order: releases cut, merged PRs (joined on one line, oldest first — a repo\n"
  printf "  with more than 8 collapses to a count), then a commit count —\n"
  printf "  ${DIM}\"on <branch>\"${X} is only added when commits are the sole event (no PRs/\n"
  printf "  releases). Plus an estate-level headline of totals.\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --since <window>  a window like 1w, 3d, 2mo ${DIM}(default: %s)${X}\n" "$SINCE"
  printf "    --md              emit clean Markdown to stdout ${DIM}(redirect to a file; backtick/\n"
  printf "                      asterisk/underscore in titles are escaped so they render clean)${X}\n\n"
  printf "  ${DIM}Network — same sources as 'log', summarized. Doubles as a contractor's\n"
  printf "  \"what I shipped\" report — client updates, invoicing notes, a brag-doc.${X}\n\n"
}
help_init(){
  printf "\n  ${BD}muninn init${X} [--force]\n\n"
  printf "  Write a config file (${DIM}%s${X}) with detected defaults — your GitHub\n" "$CONFIG"
  printf "  login and estate root. Edit it afterward.\n\n"
  printf "  ${BD}Config keys${X} ${DIM}(an env MUNINN_* var overrides the file)${X}\n"
  printf "    MUNINN_ROOT · MUNINN_OWNER · MUNINN_FAMILY · MUNINN_SINCE\n\n"
  printf "  ${DIM}If ~/.config/huginn/config exists and MUNINN_* is unset, muninn falls back\n"
  printf "  to its HUGINN_ROOT/HUGINN_OWNER/HUGINN_FAMILY — a huginn user gets a working\n"
  printf "  muninn with zero setup.${X}\n\n"
}

# ── help ────────────────────────────────────────────────────────────────────
cmd_help(){
  printf "\n  ${BD}muninn${X} ${DIM}— memory for your GitHub estate · %s${X}\n\n" "$ROOT"
  printf "  ${DIM}remember${X}\n"
  printf "    ${BD}log${X} [--since <window>] [repo]      activity timeline — PRs, releases, commits\n"
  printf "    ${BD}releases${X}                           every tag/release across the estate\n"
  printf "    ${BD}digest${X} [--since <window>] [--md]   a written summary of what shipped\n"
  printf "  ${DIM}configure${X}\n"
  printf "    ${BD}init${X} [--force]                     write a muninn config with detected defaults\n"
  printf "    ${BD}help${X}                               this menu\n\n"
  printf "  ${DIM}run${X} ${BD}muninn <command> help${X} ${DIM}for details & options on any command.${X}\n\n"
}

case "${1:-help}" in
  log)      shift; cmd_log "$@";;
  releases) shift; cmd_releases "$@";;
  digest)   shift; cmd_digest "$@";;
  init)     shift; cmd_init "$@";;
  help|-h|--help) cmd_help;;
  *) printf "${R}unknown command: %s${X}\n" "$1"; cmd_help; exit 1;;
esac
